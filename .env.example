# Copy this file to .env and fill in values. Never commit .env.

# Option A: paste the entire service account JSON as a single line (escape internal quotes if needed, or use JSON.stringify one-liner)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option B: path to the downloaded JSON key file (recommended for local dev)
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# From your Google Sheet URL: .../spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=

# From your Drive folder URL: .../folders/FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=

# Server port when running npm start
PORT=3000
